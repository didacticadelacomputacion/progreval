        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <conMarcoDeTrabajo rdf:resource="urn:protege:ontology:progreval#Tablero-con-bolitas"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#basico"/>
        <Enunciado>Escribir un programa que ponga un cuadrado de tamaño 3 con bolitas de color Verde, con centro en la celda actual.</Enunciado>
        <Respuesta>FUNCION PonerCuadrado(){
    Poner(Verde)
    Mover(Oeste)
    Poner(Verde)
    Mover(Norte)
    Poner(Verde)
    Mover(Este)
    Poner(Verde)
    Mover(Este)
    Poner(Verde)
    Mover(Sur)
    Poner(Verde)
    Mover(Sur)
    Poner(Verde)
    Mover(Oeste)
    Poner(Verde)
    Mover(Oeste)
    Poner(Verde)
    Mover(Este)
    Mover(Norte)
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#depurar-dibujar-cuadrado-de-lado-2 -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#depurar-dibujar-cuadrado-de-lado-2">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Primario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <conMarcoDeTrabajo rdf:resource="urn:protege:ontology:progreval#Tablero-con-bolitas"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#funcion-depuracion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#avanzado"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-modificacion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-seguimiento"/>
        <Enunciado>Explicar por qué el siguiente programa no funciona y corregirlo.
 Consejo: mejorar los nombres de las funciones y parámetros.

FUNCION DibujarCuadrado_De2CeldasDeLado(colorDelCuadrado){
    /*
       PROPÓSITO: Dibuja un cuadrado sólido de 2x2 de color **colorDelCuadrado**.
       PARÁMETROS:
    	* colorDelCuadrado: Un color del cual se dibujará el cuadrado.
       PRECONDICIONES:
    	* Existen al menos 1 celda al Norte y 1 al Este de la actual.
    */
    
    Línea2()
    Mover(Norte)
    Línea2()
    Mover(Sur)
} 

FUNCION Línea2(){
    /*
    PROPÓSITO: Dibujar una línea de longitud 2 de color **colorCuadrado**
    PRECONDICIONES: existe al menos 1 celda al Este de la actual
    */
    
    Poner(colorCuadrado)
    Mover(Este)
    Poner(colorCuadrado)
    Mover(Oeste)
}</Enunciado>
        <Respuesta>El parámetro colorDelCuadrado no alcanza a la función LíneaDe2CeldasHaciaElEste, debe pasársele por parámetro.

FUNCION DibujarCuadrado_De2CeldasDeLado(colorDelCuadrado){
    /*
        PROPÓSITO: Dibuja un cuadrado sólido de 2x2 de color **colorDelCuadrado**.
        PARÁMETROS:
    	* colorDelCuadrado: Un color del cual se dibujará el cuadrado.
        PRECONDICIONES:
    	* Existen al menos 1 celda al Norte y 1 al Este de la actual.
    */
    
    LíneaDe2CeldasHaciaElEste(colorDelCuadrado)
    Mover(Norte)
    LíneaDe2CeldasHaciaElEste(colorDelCuadrado)
    Mover(Sur)
} 

FUNCION LíneaDe2CeldasHaciaElEste(colorLínea){
    /*
       PROPÓSITO: Dibujar una línea de longitud 2 de color **colorLínea**
       PARÁMETROS:
    	* colorLínea: Un color del cual se dibujará la línea
       PRECONDICIONES: existe al menos 1 celda al Este de la actual
    */
    
    Poner(colorLínea)
    Mover(Este)
    Poner(colorLínea)
    Mover(Oeste)
}</Respuesta>
    </owl:NamedIndividual>
    


