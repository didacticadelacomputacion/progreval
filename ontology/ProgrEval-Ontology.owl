    <!-- urn:protege:ontology:progreval#verificar-acceso-montaña-rusa -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#verificar-acceso-montaña-rusa">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Primario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#basico"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <Enunciado xml:lang="es-ar">Escriba un programa para controlar la entrada a una montaña rusa. El programa debe recibir como entrada la altura de una persona en centímetros. Si la altura es menor a 140 cm, el programa debe mostrar el mensaje &quot;Acceso denegado: altura insuficiente&quot;. En caso contrario (140 cm o más), debe mostrar &quot;Acceso permitido&quot;.</Enunciado>
        <Respuesta>FUNCION VerificarAcceso(altura){
    SI altura &lt; 140 ENTONCES {
        IMPRIMIR &quot;Acceso denegado: altura insuficiente&quot;
    }SINO{
        IMPRIMIR &quot;Acceso permitido&quot;
    }
}</Respuesta>
    </owl:NamedIndividual>
</rdf:RDF>



