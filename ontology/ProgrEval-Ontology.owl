    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- urn:protege:ontology:progreval#apuntadaA -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#apuntadaA">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Consigna-Modelo"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Publico-Objetivo"/>
        <rdfs:label>apuntadoA</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#conMarcoDeTrabajo -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#conMarcoDeTrabajo">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Consigna-Modelo"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#concepto -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#concepto">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Complejidad-Concepto"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#conceptoEvaluadoPor -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#conceptoEvaluadoPor">
        <owl:inverseOf rdf:resource="urn:protege:ontology:progreval#evaluaConcepto"/>
        <rdfs:label xml:lang="es-ar">conceptoEvaluadoPor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#conllevaEsfuerzoDeCorreccion -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#conllevaEsfuerzoDeCorreccion">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Esfuerzo-Correccion"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#desempeñoEvaluadoPor -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#desempeñoEvaluadoPor">
        <owl:inverseOf rdf:resource="urn:protege:ontology:progreval#evaluaDesempeño"/>
        <rdfs:label xml:lang="es-ar">evaluadoPor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#ejemplificadoPor -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#ejemplificadoPor">
        <owl:inverseOf rdf:resource="urn:protege:ontology:progreval#esEjemploDe"/>
        <rdfs:label xml:lang="es-ar">ejemplificadoPor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#empleaDesempeño -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#empleaDesempeño">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Habilidad"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#empleaDesempeñoSobre -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#empleaDesempeñoSobre">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Habilidad"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#esEjemploDe -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#esEjemploDe">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Consigna-Modelo"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Tipo-Consigna"/>
        <rdfs:label xml:lang="es-ar">esEjemploDe</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#evaluaConcepto -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#evaluaConcepto">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Tipo-Consigna"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
        <rdfs:label xml:lang="es-ar">evaluaConcepto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#evaluaConceptoANivel -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#evaluaConceptoANivel">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Consigna-Modelo"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Nivel-Complejidad"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#evaluaDesempeño -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#evaluaDesempeño">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Tipo-Consigna"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <rdfs:label xml:lang="es-ar">evalua</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#nivel -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#nivel">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Complejidad-Concepto"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Nivel-Complejidad"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#requiereManejoDe -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#requiereManejoDe">
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Consigna-Modelo"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Habilidad"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#usaFormato -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#usaFormato">
        <owl:inverseOf rdf:resource="urn:protege:ontology:progreval#usadoPor"/>
        <rdfs:domain rdf:resource="urn:protege:ontology:progreval#Tipo-Consigna"/>
        <rdfs:range rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
    </owl:ObjectProperty>
    


    <!-- urn:protege:ontology:progreval#usadoPor -->

    <owl:ObjectProperty rdf:about="urn:protege:ontology:progreval#usadoPor">
        <rdfs:label xml:lang="es-ar">usadoPor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- urn:protege:ontology:progreval#Dominio -->

    <owl:DatatypeProperty rdf:about="urn:protege:ontology:progreval#Dominio"/>
    


    <!-- urn:protege:ontology:progreval#Enunciado -->

    <owl:DatatypeProperty rdf:about="urn:protege:ontology:progreval#Enunciado"/>
    


    <!-- urn:protege:ontology:progreval#Respuesta -->

    <owl:DatatypeProperty rdf:about="urn:protege:ontology:progreval#Respuesta"/>
    


    <!-- urn:protege:ontology:progreval#Tabla-Valores -->

    <owl:DatatypeProperty rdf:about="urn:protege:ontology:progreval#Tabla-Valores"/>
    


    <!-- urn:protege:ontology:progreval#orden -->

    <owl:DatatypeProperty rdf:about="urn:protege:ontology:progreval#orden">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- urn:protege:ontology:progreval#Complejidad-Concepto -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Complejidad-Concepto">
        <rdfs:label>Complejidad por concepto</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Concepto-Fundamental -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Concepto-Fundamental">
        <dc:description>Acá hay que poner información sobre el rol que cumple este parámetro</dc:description>
        <rdfs:label>Concepto fundamental</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Consigna-Modelo -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Consigna-Modelo">
        <rdfs:label>Consigna modelo</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Desempeño -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Desempeño">
        <dc:description>Acá hay que poner información sobre el rol que cumple este parámetro</dc:description>
        <rdfs:label xml:lang="es-ar">Desempeño</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Esfuerzo-Correccion -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Esfuerzo-Correccion">
        <rdfs:label>Esfuerzo de correccion</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Formato-Consigna -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Formato-Consigna">
        <dc:description>Acá hay que poner información sobre el rol que cumple este parámetro</dc:description>
        <rdfs:label>Formato de consigna</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Habilidad -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Habilidad">
        <rdfs:comment>Siempre que se agregue una nueva habilidad habrá que incorporarla a la lista de Equivalent to para que sea reconocida por el razonador. Además, deberá agregarse a regla &quot;(requiereManejode NuevaHabilidad) or (noRequiereManejoDe NuevaHabilidad)&quot; al axioma de SubClass of de Enunciado-Modelo.</rdfs:comment>
        <rdfs:label>Habilidad</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Marco-de-Trabajo -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Marco-de-Trabajo"/>
    


    <!-- urn:protege:ontology:progreval#Nivel-Complejidad -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Nivel-Complejidad">
        <dc:description>Acá hay que poner información sobre el rol que cumple este parámetro</dc:description>
        <rdfs:label>Nivel de complejidad</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Publico-Objetivo -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Publico-Objetivo">
        <dc:description>Acá hay que poner información sobre el rol que cumple este parámetro</dc:description>
        <rdfs:label>Público Objetivo</rdfs:label>
    </owl:Class>
    


    <!-- urn:protege:ontology:progreval#Tipo-Consigna -->

    <owl:Class rdf:about="urn:protege:ontology:progreval#Tipo-Consigna">
        <rdfs:label>Tipo de consigna</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- urn:protege:ontology:progreval#Complecion-de-Espacios-Vacios -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Complecion-de-Espacios-Vacios">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
        <conllevaEsfuerzoDeCorreccion rdf:resource="urn:protege:ontology:progreval#semi-automatico"/>
        <dc:description xml:lang="es-ar">Consigna que presenta un programa o una expresión lógica donde hay que completar sus partes faltantes (2 o más espacios en blanco) elaborando manualmente el contenido necesario para que cumpla con su definición. Los espacios en blanco corresponden a elementos directamente relacionados con el concepto a evaluar.</dc:description>
        <rdfs:label>Compleción de espacios vacíos</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Complecion-de-Espacios-Vacios-con-Opciones -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Complecion-de-Espacios-Vacios-con-Opciones">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
        <conllevaEsfuerzoDeCorreccion rdf:resource="urn:protege:ontology:progreval#automatico"/>
        <dc:description>Consigna que presenta un programa o una expresión lógica donde hay que completar sus partes faltantes (2 o más espacios en blanco) a partir de una lista de opciones posibles para que cumpla con su definición. La lista puede contener distractores que no corresponden a ningún espacio.</dc:description>
        <rdfs:label>Compleción de espacios vacíos con opciones posibles</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Definicion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Definicion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description xml:lang="es-ar">Habilidad para determinar cómo debe estar definida una expresión o componente de un programa para que cumpla un propósito determinado, entendiendo como componente a tipos de datos estructurados, variables y funciones.</dc:description>
        <rdfs:label>Definición</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Depuracion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Depuracion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description>Habilidad para identificar y reparar las causas de comportamientos indeseados en una pieza de código.</dc:description>
        <rdfs:label>Depuración</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Directiva-de-Repeticion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Directiva-de-Repeticion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
        <dc:description xml:lang="es-ar">Directivas provistas por los lenguajes de programación para definir la repetición de secuencias de cómputo. En la mayoría de los lenguajes imperativos podemos definir bucles usando directivas como while y for.</dc:description>
        <rdfs:label>Directiva de Repetición</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Directiva-de-Seleccion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Directiva-de-Seleccion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
        <dc:description xml:lang="es-ar">Directivas provistas por los lenguajes de programación para definir bifurcaciones en el flujo de un programa. En la mayoría de los lenguajes imperativos podemos definirlas usando directivas como If-Then-Else y Switch-Case.</dc:description>
        <rdfs:label>Directiva de Selección</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Emparejamiento-de-opciones -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Emparejamiento-de-opciones">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
        <conllevaEsfuerzoDeCorreccion rdf:resource="urn:protege:ontology:progreval#automatico"/>
        <dc:description>Consignas en las que se presentan dos o más grupos de elementos que deben emparejarse de acuerdo a alguna relación establecida.</dc:description>
        <rdfs:label>Emparejamiento de opciones</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Especificacion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Especificacion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description>Habilidad para describir formalmente las características de una solución o sistema.</dc:description>
        <rdfs:label>Especificación</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Esquematizacion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Esquematizacion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description xml:lang="es-ar">Habilidad para representar ideas mediante esquemas y diagramas.</dc:description>
        <rdfs:label>Esquematización</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Evaluacion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Evaluacion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description xml:lang="es-ar">Habilidad para obtener el resultado de una expresión o función, dados los valores de sus variables o parámetros.</dc:description>
        <rdfs:label>Evaluación</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Explicacion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Explicacion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description xml:lang="es-ar">Habilidad para poner ideas y razonamientos en palabras.</dc:description>
        <rdfs:label>Explicación</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Expresion-Logica -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Expresion-Logica">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
        <dc:description xml:lang="es-ar">Expresiones de la lógica proposicional, tablas de verdad y predicados de relación.</dc:description>
        <rdfs:label>Expresión Lógica</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Expresion-Matematica -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Expresion-Matematica">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
        <dc:description xml:lang="es-ar">Expresiones aritméticas.</dc:description>
        <rdfs:label>Expresión Matemática</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Funcion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Funcion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Concepto-Fundamental"/>
        <dc:description xml:lang="es-ar">Porción de código parametrizado a la que se le da un nombre para poder referenciarlo en varios puntos de un programa. Consideramos como funciones puras a funciones sin efectos secundarios que retornan un valor, y como funciones impuras o procedimientos a funciones que alteran el estado del programa y no retornan ningún valor.</dc:description>
        <rdfs:label>Función</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Implementacion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Implementacion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description xml:lang="es-ar">Habilidad para diseñar y construir un programa que cumpla con un objetivo dado.</dc:description>
        <rdfs:label>Implementación</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Modificacion -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Modificacion">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Desempeño"/>
        <dc:description xml:lang="es-ar">Habilidad para tomar un programa, comprenderlo y modificar su comportamiento o expandirlo.</dc:description>
        <rdfs:label>Modificación</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Nivel-Inicial -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Nivel-Inicial">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Publico-Objetivo"/>
        <rdfs:label>Nivel inicial</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Nivel-Universitario -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Nivel-Universitario">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Publico-Objetivo"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-seguimiento-opcion-multiple"/>
        <rdfs:label>Nivel universitario</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Opcion-Multiple-Respuesta-Multiple -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Opcion-Multiple-Respuesta-Multiple">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
        <conllevaEsfuerzoDeCorreccion rdf:resource="urn:protege:ontology:progreval#automatico"/>
        <dc:description>Consignas en las que se presentan opciones como potenciales soluciones. Varias de las opciones son correctas. Las que no, son distractores diseñados para ser el resultado de errores conceptuales comunes.</dc:description>
        <rdfs:label>Opción múltiple con respuestas múltiples</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Opcion-Multiple-Respuesta-Unica -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Opcion-Multiple-Respuesta-Unica">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
        <conllevaEsfuerzoDeCorreccion rdf:resource="urn:protege:ontology:progreval#automatico"/>
        <dc:description xml:lang="es-ar">Consignas en las que se presentan opciones como potenciales soluciones. Una es correcta y las demás son distractores diseñados para ser el resultado de errores conceptuales comunes.</dc:description>
        <rdfs:label>Opción múltiple con respuesta única</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#Parsons -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#Parsons">
        <rdf:type rdf:resource="urn:protege:ontology:progreval#Formato-Consigna"/>
        <conllevaEsfuerzoDeCorreccion rdf:resource="urn:protege:ontology:progreval#automatico"/>
        <dc:description>Consigna en la que se deben ordenar las instrucciones de un programa para resolver una tarea específica. Se provee una lista de instrucciones entre las que se encuentran las necesarias para resolver el problema y otras innecesarias que cumplen el rol de distractoras.</dc:description>
