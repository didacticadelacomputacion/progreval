    <!-- urn:protege:ontology:progreval#traduccion-de-calificaciones -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#traduccion-de-calificaciones">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-matematica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <Enunciado xml:lang="es-ar">Una universidad requiere una función para traducir calificaciones numéricas (0 a 100) a letras según la siguiente escala:

90 a 100: &apos;A&apos;

80 a 89: &apos;B&apos;

70 a 79: &apos;C&apos;

Menos de 70: &apos;F&apos; 

Implemente una función que reciba el puntaje numérico y devuelva la letra correspondiente. Asuma que el puntaje ingresado siempre es válido (entre 0 y 100).</Enunciado>
        <Respuesta>FUNCION ConvertirNota(puntaje){
    SI puntaje &gt;= 90 ENTONCES{
        RETORNAR &apos;A&apos;
    }SINO SI puntaje &gt;= 80 ENTONCES{
        RETORNAR &apos;B&apos;
    }SINO SI puntaje &gt;= 70 ENTONCES{
        RETORNAR &apos;C&apos;
    }SINO{
        RETORNAR &apos;F&apos;
    }
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#validacion-de-fechas -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#validacion-de-fechas">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#avanzado"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-matematica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <Enunciado xml:lang="es">Implemente una función EsFechaValida(dia, mes, anio) que reciba tres enteros y devuelva VERDADERO si la fecha es válida en el calendario gregoriano, o FALSO en caso contrario. Considere que:

- Los meses tienen días estándar (Enero 31, Abril 30, etc.).

- Febrero tiene 28 días, excepto en años bisiestos donde tiene 29.

Un año es bisiesto si es divisible por 4, pero no por 100, a menos que también sea divisible por 400. Asuma que el año debe ser mayor a 0.</Enunciado>
        <Respuesta>FUNCION EsFechaValida(dia, mes, año){
    SI (año &lt; 1 O mes &lt; 1 O mes &gt; 12 O dia &lt; 1) ENTONCES{
        RETORNAR FALSO
    }

    VARIABLE diasEnMes

    SEGUN mes HACER{
        CASO 4, 6, 9, 11:
            diasEnMes = 30
        CASO 2:
            // Lógica de año bisiesto
            SI (año % 4 == 0 Y año % 100 != 0) O (año % 400 == 0) ENTONCES{
                diasEnMes = 29
            }SINO{
                diasEnMes = 28
            }
        DE_OTRO_MODO: // Meses 1, 3, 5, 7, 8, 10, 12
            diasEnMes = 31
    }

    SI dia &lt;= diasEnMes ENTONCES{
        RETORNAR VERDADERO
    }SINO{
        RETORNAR FALSO
    }
}</Respuesta>
    </owl:NamedIndividual>
    


