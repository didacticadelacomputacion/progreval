    <!-- urn:protege:ontology:progreval#completar-tablero-con-16-bolitas -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#completar-tablero-con-16-bolitas">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-implementacion-complecion-espacios-vacios"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#basico"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <Enunciado>Completar la siguiente función para que al ejecutarse sobre un tablero de 1 fila y 2 columnas, comenzando desde el casillero Oeste, coloque 10 bolitas azules en casillero inicial y 6 bolitas rojas en el casillero Este.

```
FUNCION CompletarTableroCon16Bolitas() {
	Poner(Rojo)
	REPETIR _ VECES {
		Poner(Azul)
	}
	Mover(_)
	REPETIR _ VECES {
		Poner(Rojo)
		Poner(Rojo)
	}
}
```</Enunciado>
        <Respuesta>```
FUNCION CompletarTableroCon16Bolitas() {
	Poner(Rojo)
	REPETIR 9 VECES {
		Poner(Azul)
	}
	Mover(_)
	REPETIR 3 VECES {
		Poner(Rojo)
		Poner(Rojo)
	}
}
```</Respuesta>
    </owl:NamedIndividual>
    


