    <!-- urn:protege:ontology:progreval#crecimiento-poblacion-bacterias -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#crecimiento-poblacion-bacterias">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-definicion"/>
        <Enunciado xml:lang="es-ar">Se desea analizar el crecimiento de una población de bacterias. La población inicial es de N bacterias y se sabe que cada hora la población se duplica.

Implementa un programa que solicite al usuario:

La cantidad inicial de bacterias (entero positivo).

Un número objetivo de bacterias a alcanzar (entero positivo).

El programa debe calcular y mostrar cuántas horas deben transcurrir para que la población supere o iguale al número objetivo. Debes utilizar un bucle para simular el crecimiento hora por hora.</Enunciado>
        <Respuesta>FUNCION calcular_horas_crecimiento(poblacion_actual, objetivo){
    horas = 0
    REPETIR MIENTRAS (poblacion_actual &lt; objetivo){
        poblacion_actual = poblacion_actual * 2
        horas += 1
    }
    RETORNAR horas
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#cuadrado-verde-de-3-de-lado -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#cuadrado-verde-de-3-de-lado">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Primario"/>
