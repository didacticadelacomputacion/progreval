    <!-- urn:protege:ontology:progreval#busqueda-lineal-con-proteccion-de-rango -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#busqueda-lineal-con-proteccion-de-rango">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-definicion-complecion-espacios-vacios"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#avanzado"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-seguimiento"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-seguimiento"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-matematica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#variable-seguimiento"/>
        <Enunciado xml:lang="es-ar">Debemos recorrer un arreglo de enteros llamado datos y un valor objetivo a buscar. Completar los espacios vacíos que correspondan con operadores de relación, operadores lógicos o paréntesis de modo que el bucle se detenga inmediatamente si se encuentra el valor o si se terminan los elementos.
La función tamañoArray(array) retorna el tamaño de un array.

FUNCION estáPresenteEnArray(valor_objetivo, datos) {
    int i = 0;
    boolean encontrado = false;
    MIENTRAS (i __ tamañoArray(datos) __ __encontrado__) HACER{
        SI (datos[i] == valor_objetivo) ENTONCES {
            encontrado = true;
        } SINO {
            i++;
        }
    }
}</Enunciado>
        <Respuesta>FUNCION estáPresenteEnArray(valor_objetivo, datos) {
    int i = 0;
    boolean encontrado = false;
    MIENTRAS (i &lt; tamañoArray(datos) &amp;&amp; !encontrado) HACER {
        SI (datos[i] == valor_objetivo) ENTONCES {
            encontrado = true;
        } SINO {
            i++;
        }
    }
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#calculadora-basica -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#calculadora-basica">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#avanzado"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <Enunciado xml:lang="es-ar">Implemente un programa que simule una calculadora básica. El programa recibe tres parámetros: dos números y un carácter que representa la operación (&apos;+&apos;, &apos;-&apos;, &apos;*&apos;, &apos;/&apos;). Dependiendo del carácter recibido, el programa debe realizar la operación matemática correspondiente y devolver el resultado. Si el carácter no corresponde a ninguna operación válida o si el valor de alguno de los operandos es inválido para la operación dada, debe devolver un mensaje de error.</Enunciado>
        <Respuesta>FUNCION CalcularOperacionBinaria(num1, num2, operador) {
    SEGUN operador HACER {
        CASO &apos;+&apos;:
            RETORNAR num1 + num2
        CASO &apos;-&apos;:
            RETORNAR num1 - num2
        CASO &apos;*&apos;:
            RETORNAR num1 * num2
        CASO &apos;/&apos;:
            SI num2 != 0 ENTONCES {
                RETORNAR num1 / num2
            }SINO{
                RETORNAR &quot;Error: División por cero&quot;
            }
        DE_OTRO_MODO:
            RETORNAR &quot;Error: Operador inválido&quot;
    }
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#clasificar-triangulo -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#clasificar-triangulo">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-matematica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#variable-definicion"/>
        <Enunciado xml:lang="es">Escriba un programa que reciba tres números reales positivos que representan las longitudes de los lados de un supuesto triángulo. El programa debe realizar dos tareas:

1 - Determinar si los lados forman un triángulo válido (la suma de dos lados cualesquiera debe ser mayor al tercero: teorema de la desigualdad triangular).

2 - Si es válido, clasificarlo e imprimir si es &quot;Equilátero&quot; (tres lados iguales), &quot;Isósceles&quot; (exactamente dos lados iguales) o &quot;Escaleno&quot; (ningún lado igual). Si no es un triángulo válido, debe imprimir &quot;No es un triángulo&quot;</Enunciado>
        <Respuesta>FUNCION ClasificarTriangulo(ladoA, ladoB, ladoC){
    // Primero validamos si es un triángulo
    SI (ladoA + ladoB &gt; ladoC) Y (ladoA + ladoC &gt; ladoB) Y (ladoB + ladoC &gt; ladoA) ENTONCES{
        // Es válido, ahora clasificamos
        SI (ladoA == ladoB) Y (ladoB == ladoC) ENTONCES{
            MOSTRAR &quot;Equilátero&quot;
        }SINO{
            SI (ladoA == ladoB) O (ladoA == ladoC) O (ladoB == ladoC) ENTONCES{
                MOSTRAR &quot;Isósceles&quot;
            }SINO{
                MOSTRAR &quot;Escaleno&quot;
            }
        }
    }SINO{
        MOSTRAR &quot;No es un triángulo&quot;
    }
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#colocar-6-bolitas -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#colocar-6-bolitas">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#basico"/>
