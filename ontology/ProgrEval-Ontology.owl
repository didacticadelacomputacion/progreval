    <!-- urn:protege:ontology:progreval#limite-de-velocidad -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#limite-de-velocidad">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-depuracion-deteccion-ocurrencia"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-seguimiento"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-seguimiento"/>
        <Enunciado>La agencia de seguridad vial está recibiendo muchos reclamos por multas de velocidad mal asignadas. Revisaron el sensor de velocidad y funciona correctamente, así que llegaron a la conclusión de que el problema está en el software que genera las alarmas. Identificar la o las causas de este problema en la función ExcedeLímiteDeVelocidad, que es la que determina si hay que multar o no.

FUNCION ExcedeLimiteDeVelocidad(velocidadRegistrada, patente){
    SI (velocidadRegistrada &lt; limiteDeVelocidad &amp;&amp; patente != &apos;&apos;){
        RegistrarMultaPara(patente)
        RETORNAR Verdadero
    } SINO { 
        RETORNAR Falso
    }
}</Enunciado>
        <Respuesta>Hay un solo error, está en velocidadRegistrada &lt; limiteDeVelocidad, que debería ser velocidadRegistrada &gt; limiteDeVelocidad.</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#longitud-de-conjetura-de-collatz -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#longitud-de-conjetura-de-collatz">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#directiva-seleccion-implementacion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-matematica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#variable-definicion"/>
        <Enunciado xml:lang="es">La conjetura de Collatz define una secuencia para un número entero positivo n de la siguiente manera:

- Si el número es par, se divide entre 2.

- Si el número es impar, se multiplica por 3 y se le suma 1.

- La secuencia termina cuando el número llega a 1.

Escribe una función AnalizarCollatz que reciba un entero inicial n y retorne la longitud de la secuencia (cuántos pasos toma llegar a 1).

Ejemplo: Si n=6, la secuencia es 6 -&gt; 3 -&gt; 10 -&gt; 5 -&gt; 16 -&gt; 8 -&gt; 4 -&gt; 2 -&gt; 1. La función debe retornar 8 (número de pasos).</Enunciado>
        <Respuesta>FUNCION AnalizarCollatz(n){
    pasos &lt;- 0
    actual &lt;- n
    
    MIENTRAS actual &gt; 1 HACER{
        
        // Lógica de decisión dentro del bucle
        SI (actual MODULO 2) == 0 ENTONCES{
            // Es par
            actual &lt;- actual / 2
        }SINO{
            // Es impar
            actual &lt;- (actual * 3) + 1
        }
        
        // Contamos un paso más
        pasos &lt;- pasos + 1
        
    }
    
    RETORNAR pasos
}</Respuesta>
    </owl:NamedIndividual>
    


