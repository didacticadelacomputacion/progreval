    <!-- urn:protege:ontology:progreval#solicitar_temperatura -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#solicitar_temperatura">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#expresion-matematica-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <Enunciado xml:lang="es-ar">Escribe un programa para un sistema de control de temperatura. El sistema debe pedir al usuario que ingrese una temperatura válida para un reactor, la cual debe estar estrictamente entre 100°C y 200°C.

Si el usuario ingresa un valor fuera de este rango, el programa debe mostrar un mensaje de error y volver a pedir el dato. Este proceso debe repetirse indefinidamente hasta que se ingrese un valor válido. Finalmente, el programa debe imprimir &apos;Temperatura aceptada&apos;.

Para solicitar un valor al usuario contamos con la función input(variable), donde variable es donde se almacenará el dato ingresado. Esta función no terminará de ejecutarse hasta que el usuario ingrese un valor.
Para imprimir mensajes podemos usar la función print(string).</Enunciado>
        <Respuesta>FUNCION solicitar_temperatura() {
    IMPRIMIR(&quot;Ingrese temperatura del reactor: &quot;)
    ENTRADA(temperatura)
    
    MIENTRAS (temperatura &lt;= 100 or temperatura &gt;= 200) HACER{
        IMPRIMIR(&quot;Error: La temperatura debe estar entre 100 y 200.&quot;)
        ENTRADA(temperatura)
    }
    IMPRIMIR(&quot;Temperatura aceptada&quot;)
}</Respuesta>
    </owl:NamedIndividual>
    


