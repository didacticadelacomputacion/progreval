    <!-- urn:protege:ontology:progreval#agregar-12-bolitas-rojas -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#agregar-12-bolitas-rojas">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-implementacion-parsons"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#basico"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion"/>
        <Enunciado>Ordenar las siguientes instrucciones para que la función tenga como propósito agregar al casillero actual 12 bolitas negras.

1. }
2. Poner(Rojo)
3. REPETIR 9 VECES {
4. FUNCION Agregar12BolitasNegras() {
5. Poner(Rojo)
6. Poner(Rojo)	
7. }
8. Poner(Rojo)</Enunciado>
        <Respuesta>Solución posible: 4, 2, 3, 5, 1, 6, 8, 7

```
FUNCION Agregar12BolitasNegras() {
	Poner(Rojo)
	REPETIR 9 VECES {
		Poner(Rojo)
	}
	Poner(Rojo)
	Poner(Rojo)
}
```</Respuesta>
    </owl:NamedIndividual>
    


