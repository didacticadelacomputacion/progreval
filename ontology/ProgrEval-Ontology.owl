    <!-- urn:protege:ontology:progreval#reloj-analogico-radio-3 -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#reloj-analogico-radio-3">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <conMarcoDeTrabajo rdf:resource="urn:protege:ontology:progreval#Tablero-con-bolitas"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#funcion-implementacion-consigna-abierta"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-definicion"/>
        <Enunciado>Dibujar un reloj analógico de agujas en un tablero cuadriculado puede ser un desafío. Una simplificación posible sería representar solamente algunos de los números que aparecen en el mismo: el 12 arriba, el 3 a la derecha, el 9 a la izquierda y el 6 abajo.
Construir una función DibujarRelojAnalógicoSimplificado(), que ponga los números del reloj tal como se indicó, alrededor del casillero actual. El tamaño del reloj será de 2 celdas de “radio” (suponiendo que miramos al reloj como un círculo).
Dividan el problema en partes más pequeñas y definan sus propias funciones para resolver cada una.</Enunciado>
        <Respuesta>FUNCION DibujarRelojAnalógicoSimplificado(){
    Dibujar12()
    Dibujar3()
    Dibujar6()
    Dibujar9()
}

FUNCION Dibujar12(){
    Mover(Norte)
    Mover(Norte)
    Poner12BolitasRojas()
    Mover(Sur)
    Mover(Sur)
}

FUNCION Dibujar3(){
    Mover(Este)
    Mover(Este)
    Poner3BolitasRojas()
    Mover(Oeste)
    Mover(Oeste)
}

FUNCION Dibujar6(){
    Mover(Sur)
    Mover(Sur)
    Poner6BolitasRojas()
    Mover(Norte)
    Mover(Norte)
}

FUNCION Dibujar9(){
    Mover(Oeste)
    Mover(Oeste)
    Poner9BolitasRojas()
    Mover(Este)
    Mover(Este)
}

FUNCION Poner12BolitasRojas(){
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
}

FUNCION Poner9BolitasRojas(){
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
}

FUNCION Poner6BolitasRojas(){
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
}

FUNCION Poner3BolitasRojas(){
    Poner(Roja)
    Poner(Roja)
    Poner(Roja)
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#reloj-analogico-radio-n -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#reloj-analogico-radio-n">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <conMarcoDeTrabajo rdf:resource="urn:protege:ontology:progreval#Tablero-con-bolitas"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#funcion-modificacion-consigna-cerrada"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#avanzado"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-seguimiento"/>
        <Enunciado>Generalizar la función DibujarRelojAnalógicoSimplificado() escribiendo una función llamada DibujarRelojAnalógicoSimplificadoDeRadio_(radio) que ponga los números del reloj como en la función original, pero donde el radio recibido por parámetro indica la distancia al centro del reloj: mientras más grande es el radio, más alejados están los números del centro.
 Se cuenta con las siguientes funciones ya implementadas:
	- Poner_DeColor_(cantidad, color): dados un valor entero para cantidad y un color, pone esa cantidad de bolitas del color indicado en la celda actual.
	- Mover_VecesAl_(cantidad, dirección): dados un valor entero para cantidad y una dirección cardinal, mueve el cabezal esa cantidad de celdas en la dirección indicada.
 La solución debe respetar las buenas prácticas de programación, renombrar las funciones para reflejar las modificaciones.

FUNCION DibujarRelojAnalógicoSimplificado(){
	
    Dibujar12()
    Dibujar3()
    Dibujar6()
    Dibujar9()
    
}

FUNCION Dibujar12(){
    Mover_VecesAl_(2, Norte)
    Poner_DeColor_(12, Rojo)
    Mover_VecesAl_(2, Sur)
}

FUNCION Dibujar3(){
    Mover_VecesAl_(2, Este)
    Poner_DeColor_(3, Rojo)
    Mover_VecesAl_(2, Oeste)
}

FUNCION Dibujar6(){
    Mover_VecesAl_(2, Sur)
    Poner_DeColor_(6, Rojo)
    Mover_VecesAl_(2, Norte)
}

FUNCION Dibujar9(){
    Mover_VecesAl_(2, Oeste)
    Poner_DeColor_(9, Rojo)
    Mover_VecesAl_(2, Este)
}</Enunciado>
        <Respuesta>FUNCION DibujarRelojAnalógicoSimplificadoDeRadio_(radio){
	
    Dibujar12ADistancia_(radio)
    Dibujar3ADistancia_(radio)
    Dibujar6ADistancia_(radio)
    Dibujar9ADistancia_(radio)
    
}

FUNCION Dibujar12ADistancia_(radio){
    Mover_VecesAl_(radio, Norte)
    Poner_DeColor_(12, Rojo)
    Mover_VecesAl_(radio, Sur)
}

FUNCION Dibujar3ADistancia_(radio){
    Mover_VecesAl_(radio, Este)
    Poner_DeColor_(3, Rojo)
    Mover_VecesAl_(radio, Oeste)
}

FUNCION Dibujar6ADistancia_(radio){
    Mover_VecesAl_(radio, Sur)
    Poner_DeColor_(6, Rojo)
    Mover_VecesAl_(radio, Norte)
}

FUNCION Dibujar9ADistancia_(radio){
    Mover_VecesAl_(radio, Oeste)
    Poner_DeColor_(9, Rojo)
    Mover_VecesAl_(radio, Este)
}</Respuesta>
    </owl:NamedIndividual>
    


