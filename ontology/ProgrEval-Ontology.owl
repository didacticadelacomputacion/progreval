        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#expresion-logica-evaluacion-consigna-cerrada"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#intermedio"/>
        <Enunciado>Obtener el valor de verdad de la siguiente expresión:

A  =&gt; B &amp; A

Tabla de valores 
A: F ; B: V</Enunciado>
        <Respuesta>V</Respuesta>
        <rdfs:label xml:lang="es-ar">Evaluar Expresión Lógica - 1</rdfs:label>
    </owl:NamedIndividual>
    


