    <!-- urn:protege:ontology:progreval#dibujar-franja-diagonal-1 -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#dibujar-franja-diagonal-1">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Primario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Segundo-Ciclo-Secundario"/>
        <conMarcoDeTrabajo rdf:resource="urn:protege:ontology:progreval#Tablero-con-bolitas"/>
        <esEjemploDe rdf:resource="urn:protege:ontology:progreval#expresion-matematica-definicion-complecion-espacios-vacios"/>
        <evaluaConceptoANivel rdf:resource="urn:protege:ontology:progreval#basico"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#directiva-repeticion-seguimiento"/>
        <requiereManejoDe rdf:resource="urn:protege:ontology:progreval#funcion-seguimiento"/>
        <Enunciado>Completar los espacios vacíos con las expresiones correspondientes para que las funciones cumplan con su propósito y las precondiciones queden correctamente definidas.

FUNCION DibujarFranjaDiagonalSuroesteANoresteDeGrosor_YLargo_DeColor_(grosor, largo, color){
     /*
     Propósito: Dibujar con bolitas de color **color** una franja diagonal ascendente de **grosor** celdas de grosor y **largo** celdas de largo, y de color **color**, empezando en el extremo inferior izquierdo y terminando en el extremo inferior derecho
     Parámetros:
            - grosor: De tipo numérico, define la cantidad de celdas verticales que ocupará la franja en cada columna. 
            - largo: De tipo numérico, define la cantidad de celdas horizontales que ocupará la franja.
            - color: De tipo color, define el color de las bolitas que compondrán la franja.
      Precondición: El tablero debe tener al menos **largo** celdas de ancho y ______ celdas de alto.
    */
    
    DibujarLíneaDeColor_DeLargo_HaciaEl_(color, grosor, Norte)
    
    REPETIR _____ VECES {
         Mover(Este)
         Mover(Norte)
         DibujarLíneaDeColor_DeLargo_HaciaEl_(color, grosor, Norte)
    }
    
}

FUNCION DibujarLíneaDeColor_DeLargo_HaciaEl_(colorLinea, largoLinea, direccion){
    /*
    Propósito: Poner **largoLinea** bolitas de color **colorLinea** desde la celda actual en la dirección **direccion**
    Parámetros:
            - colorLinea: De tipo color, define el color de las bolitas que componen la línea
            - largoLinea: De tipo numérico, define el largo que tendrá la línea a dibujar.
            - direccion: De tipo dirección cardinal, define la dirección en la que se dibujará la línea.
    Precondición: El tablero debe tener al menos _____ celdas hacia **direccion**.
    */
    
    Poner(colorLinea)
    REPETIR _____ VECES{
        Mover(direccion)
        Poner(colorLinea)
    }
    
    REPETIR _____ VECES{
        Mover(opuesto(direccion))
    }
    
}</Enunciado>
        <Respuesta>FUNCION DibujarFranjaDiagonalSuroesteANoresteDeGrosor_YLargo_DeColor_(grosor, largo, color){
	/*
    	Propósito: Dibujar con bolitas de color **color** una franja diagonal ascendente de **grosor** celdas de grosor y **largo** celdas de largo, y de color **color**, empezando en el extremo inferior izquierdo y terminando en el extremo inferior derecho
    	Parámetros:
        	- grosor: De tipo numérico, define la cantidad de celdas verticales que ocupará la franja en cada columna. 
        	- largo: De tipo numérico, define la cantidad de celdas horizontales que ocupará la franja.
            - color: De tipo color, define el color de las bolitas que compondrán la franja.
        Precondición: El tablero debe tener al menos **largo** celdas de ancho y **grosor**+**largo** celdas de alto.
    */
    
    DibujarLíneaDeColor_DeLargo_HaciaEl_(color, grosor, Norte)
    
    REPETIR largo-1 VECES {
    	Mover(Este)
        Mover(Norte)
    	DibujarLíneaDeColor_DeLargo_HaciaEl_(color, grosor, Norte)
    }
    
}

FUNCION DibujarLíneaDeColor_DeLargo_HaciaEl_(colorLinea, largoLinea, direccion){
    /*
    Propósito: Poner **largoLinea** bolitas de color **colorLinea** desde la celda actual en la dirección **direccion**
    Parámetros:
            - colorLinea: De tipo color, define el color de las bolitas que componen la línea
            - largoLinea: De tipo numérico, define el largo que tendrá la línea a dibujar.
            - direccion: De tipo dirección cardinal, define la dirección en la que se dibujará la línea.
    Precondición: El tablero debe tener al menos **grosor** celdas hacia **direccion**.
    */
    
    Poner(colorLinea)
    REPETIR largoLinea - 1 VECES{
        Mover(direccion)
        Poner(colorLinea)
    }
    
    REPETIR largoLinea - 1 VECES{
        Mover(opuesto(direccion))
    }
    
}</Respuesta>
    </owl:NamedIndividual>
    


    <!-- urn:protege:ontology:progreval#dibujar-franja-diagonal-2 -->

    <owl:NamedIndividual rdf:about="urn:protege:ontology:progreval#dibujar-franja-diagonal-2">
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Nivel-Universitario"/>
        <apuntadaA rdf:resource="urn:protege:ontology:progreval#Primer-Ciclo-Secundario"/>
